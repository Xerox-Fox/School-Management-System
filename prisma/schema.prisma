generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  displayId  String   @unique
  name       String
  email      String   @unique
  password   String
  phone      String
  address    String
  userType   String   // 'student', 'teacher', 'parent', 'root', 'admin'
  subject    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
